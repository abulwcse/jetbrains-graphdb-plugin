<!-- ============================================================================
     GraphDB Plugin — plugin.xml
     This file is the primary descriptor for the JetBrains plugin runtime.
     It declares the plugin identity, dependencies, extension points, services,
     actions, and all UI contributions such as tool windows.
     ============================================================================ -->
<idea-plugin>

    <!-- ========================================================================
         Plugin Identity
         id         : unique reverse-DNS identifier; never changes after publishing
         name       : human-readable name shown in the Marketplace and Settings UI
         version    : kept in sync with gradle.properties / build.gradle.kts
         ======================================================================== -->
    <id>com.graphdbplugin</id>
    <name>GraphDB for Neo4j</name>
    <version>1.4.4</version>

    <!-- ========================================================================
         Vendor Information
         ======================================================================== -->
    <vendor url="https://github.com/abulwcse/jetbrains-graphdb-plugin" email="abul.cse@gmail.com">
        Abul Hassan Anwar Hussin
    </vendor>

    <!-- ========================================================================
         Plugin Description (shown on the Marketplace listing page and in
         Settings → Plugins → description panel).
         Must be valid HTML.
         ======================================================================== -->
    <description><![CDATA[
        <h2>GraphDB for Neo4j — Neo4j / Bolt Database Manager for JetBrains IDEs</h2>
        <p>
            <b>GraphDB for Neo4j</b> brings Neo4j graph database tooling directly into your JetBrains IDE.
            Connect to any Neo4j instance via the Bolt protocol, write and execute Cypher queries with
            full language support, and explore results as an interactive graph canvas or a data table —
            without leaving your editor.
        </p>

        <h3>What you can do today</h3>
        <ul>
            <li><b>Data source management</b> — add, edit and delete Bolt connections with per-source colour coding;
                supports all URL schemes (<code>bolt://</code>, <code>bolt+s://</code>, <code>neo4j://</code>,
                <code>neo4j+s://</code>, etc.)</li>
            <li><b>Secure credentials</b> — passwords are stored in the OS keychain via the IDE's built-in
                PasswordSafe; never written to disk in plain text</li>
            <li><b>Test Connection</b> — verify connectivity (including SSL and named databases) before saving</li>
            <li><b>Persistent data sources</b> — your connections survive IDE restarts</li>
            <li><b>Cypher editor</b> — dedicated <code>.cypher</code> / <code>.cql</code> file type with syntax
                highlighting (keywords, functions, operators, strings, comments), auto-completion, live error
                annotations, and <code>//</code> / <code>/* */</code> commenting shortcuts</li>
            <li><b>Run queries</b> — execute with <code>Ctrl+F5</code> (Windows/Linux) or <code>Cmd+F5</code>
                (macOS) against the selected data source and target database</li>
            <li><b>Graph visualisation</b> — interactive force-directed canvas; scroll to pan,
                <code>Ctrl+scroll</code> to zoom, drag to reposition, double-click a node to inspect
                all its properties; colour-coded legend by node label</li>
            <li><b>Table view</b> — raw rows and columns for scalar and list results</li>
            <li><b>Query log</b> — terminal-style history of every query run in the session</li>
            <li><b>Parameters panel</b> — set named <code>$param</code> values as JSON before running</li>
        </ul>

        <h3>Planned for upcoming releases</h3>
        <ul>
            <li>Schema browser — explore labels, relationship types, property keys and indexes live from
                the connected database</li>
            <li>Query history and saved/favourite queries</li>
            <li>Export results as CSV or JSON</li>
            <li>Multi-statement execution and transaction control</li>
            <li>Expanded IDE compatibility (WebStorm, PyCharm, Rider, …)</li>
        </ul>

        <h3>Bugs and feature requests</h3>
        <p>
            Please open an issue or start a discussion on
            <a href="https://github.com/abulwcse/jetbrains-graphdb-plugin/issues/new">GitHub</a>.
            Include your IDE version, plugin version, and steps to reproduce for bug reports.
        </p>

        <p><i>Requires IntelliJ IDEA 2024.3 or later and a running Neo4j 5.x instance.</i></p>
    ]]></description>

    <!-- ========================================================================
         Change Notes — shown in the Marketplace version history.
         ======================================================================== -->
    <change-notes><![CDATA[
        <b>1.4.4</b>
        <ul>
            <li>Fixed data-source list losing all field values (name, URL, credentials)
                after a plugin update. <code>BoltDataSource</code> properties were
                declared <code>val</code> (immutable), so IntelliJ's XML deserialiser
                could construct each item but could not set any fields — every entry
                appeared with an empty name and default URL. Properties are now
                <code>var</code> so the deserialiser can populate them correctly.</li>
            <li>Active data-source selection is now persisted per project to
                <code>graphdb-project.xml</code> and survives IDE restarts and
                plugin updates.</li>
        </ul>
        <b>1.4.3</b>
        <ul>
            <li>Removed use of internal API <code>ApplicationInitializedListener</code>.
                <code>CypherLanguage</code> is now a plain class whose singleton instance is
                initialised eagerly in a companion-object static initialiser, guaranteeing
                language registration on the main thread at class-load time without relying
                on any internal platform hooks. GoLand 2026.1 compatibility is preserved.</li>
        </ul>
        <b>1.4.2</b>
        <ul>
            <li>Fixed CI/CD publish workflow failing on Ubuntu runner due to macOS-specific
                Homebrew JDK path in <code>gradle.properties</code>.</li>
        </ul>
        <b>1.4.1</b>
        <ul>
            <li>Updated Marketplace listing: vendor details, full plugin description covering
                all current features, issue/feature-request link, and plugin icon.</li>
            <li>Added CI/CD workflow to publish automatically to JetBrains Marketplace on release.</li>
        </ul>
        <b>1.4.0</b>
        <ul>
            <li>Fixed URL validation to accept TLS-scheme URLs (<code>bolt+s://</code>,
                <code>bolt+ssc://</code>, <code>neo4j+s://</code>, <code>neo4j+ssc://</code>).
                Previously these were rejected by the "Add / Edit Data Source" dialog,
                making it impossible to save SSL-enabled data sources.</li>
            <li>Fixed connection-test in the tool window: the configured database is now
                passed to the session, so the test accurately reflects connectivity to the
                target database rather than always pinging the server's default database.</li>
        </ul>
        <b>1.3.0</b>
        <ul>
            <li>Fixed <code>NoClassDefFoundError: CypherLanguage</code> crash when opening a Cypher
                editor in GoLand 2026.1 (build 261). The IntelliJ Platform 261 tightened
                language-registration timing; CypherLanguage is now eagerly registered at
                application startup via <code>ApplicationInitializedListener</code>.</li>
            <li>All token-type, composite-element-type and parser-companion fields that
                reference CypherLanguage are now lazily initialised, eliminating the
                premature class-load race that caused the crash.</li>
            <li>Fixed data-source persistence: multiple data sources now survive IDE
                restarts (<code>DataSourceManagerState.dataSources</code> changed to
                <code>var</code>; <code>BoltDataSource.name</code> given a default value
                to support XML deserialisation).</li>
        </ul>
        <b>1.2.0</b>
        <ul>
            <li>Extended IDE compatibility to cover GoLand 2026.1 (build 261).</li>
        </ul>
        <b>1.1.0</b>
        <ul>
            <li>Extended IDE compatibility to cover GoLand 2025.1 – 2025.3 (builds 251–253).</li>
        </ul>
        <b>1.0.0</b>
        <ul>
            <li>Initial Phase 1 release: data-source management, Bolt connectivity,
                OS keychain password storage.</li>
        </ul>
    ]]></change-notes>

    <!-- ========================================================================
         Platform Dependency
         com.intellij.modules.platform is satisfied by every JetBrains IDE and
         is the minimal dependency for a platform-level plugin.
         ======================================================================== -->
    <depends>com.intellij.modules.platform</depends>

    <!-- ========================================================================
         Extensions
         Each <extensions defaultExtensionNs="com.intellij"> block registers
         contributions to IntelliJ Platform extension points.
         ======================================================================== -->
    <extensions defaultExtensionNs="com.intellij">

        <!-- ====================================================================
             Tool Window
             Adds the "GraphDB" panel to the IDE sidebar.
               id           : used in action references and programmatic lookup
               anchor       : docks the window to the right stripe by default
               icon         : path inside the resources root (loaded via IconLoader)
               factoryClass : creates the Swing content when the window is first shown
             ==================================================================== -->
        <toolWindow
            id="GraphDB"
            anchor="right"
            icon="/icons/graphdb.svg"
            factoryClass="com.graphdbplugin.toolwindow.GraphDbToolWindowFactory"
            doNotActivateOnStart="true"/>

        <!-- ====================================================================
             Application-Level Service: DataSourceManager
             Persists the list of Bolt data sources across IDE restarts.
             Registered at the application level so data sources are shared
             across all open projects in the same IDE instance.
             ==================================================================== -->
        <applicationService
            serviceInterface="com.graphdbplugin.datasource.DataSourceManager"
            serviceImplementation="com.graphdbplugin.datasource.DataSourceManager"/>

        <!-- ====================================================================
             Project-Level Service: GraphDbProjectService
             Tracks per-project state such as the currently active data source.
             ==================================================================== -->
        <projectService
            serviceInterface="com.graphdbplugin.services.GraphDbProjectService"
            serviceImplementation="com.graphdbplugin.services.GraphDbProjectService"/>

        <!-- ====================================================================
             Notification Group
             Used to display balloon notifications for connection events,
             errors and informational messages from the plugin.
             ==================================================================== -->
        <notificationGroup
            id="GraphDB.Notifications"
            displayType="BALLOON"
            key="notification.group.graphdb"/>

        <!-- ====================================================================
             Project-Level Service: SchemaIntrospectionService
             Caches graph schema metadata (labels, relationship types, property
             keys) fetched asynchronously from the connected Neo4j instance.
             ==================================================================== -->
        <projectService
            serviceInterface="com.graphdbplugin.services.SchemaIntrospectionService"
            serviceImplementation="com.graphdbplugin.services.SchemaIntrospectionService"/>

        <!-- ====================================================================
             Cypher File Type
             Registers the .cypher and .cql file extensions so the IDE
             associates them with the Cypher language and routes them through
             the Cypher lexer, parser, and highlighter.
             ==================================================================== -->
        <fileType name="Cypher"
                  implementationClass="com.graphdbplugin.language.CypherFileType"
                  fieldName="INSTANCE"
                  language="Cypher"
                  extensions="cypher;cql"/>

        <!-- ====================================================================
             Cypher Language Parser
             Supplies the ParserDefinition that the IntelliJ Platform uses to
             lex and parse Cypher source files into a PSI tree.
             ==================================================================== -->
        <lang.parserDefinition language="Cypher"
            implementationClass="com.graphdbplugin.language.parser.CypherParserDefinition"/>

        <!-- ====================================================================
             Cypher Syntax Highlighting
             Factory that creates a CypherSyntaxHighlighter on demand, enabling
             token-based colouring in the editor and diff views.
             ==================================================================== -->
        <lang.syntaxHighlighterFactory language="Cypher"
            implementationClass="com.graphdbplugin.language.highlighting.CypherSyntaxHighlighterFactory"/>

        <!-- ====================================================================
             Color Settings Page for Cypher
             Adds a "Cypher" node under Settings → Editor → Color Scheme so
             users can customise keyword, comment, string colours, etc.
             ==================================================================== -->
        <colorSettingsPage
            implementationClass="com.graphdbplugin.language.highlighting.CypherColorSettingsPage"/>

        <!-- ====================================================================
             Cypher Completion Contributor
             Provides keyword and schema-aware code completion for .cypher files.
             ==================================================================== -->
        <completion.contributor language="Cypher"
            implementationClass="com.graphdbplugin.language.completion.CypherCompletionContributor"/>

        <!-- ====================================================================
             Cypher Completion Confidence
             Enables auto-popup (typing-triggered) completion for Cypher files,
             suppressing the popup only inside string literals and comments.
             ==================================================================== -->
        <completion.confidence language="Cypher"
            implementationClass="com.graphdbplugin.language.completion.CypherCompletionConfidence"/>

        <!-- ====================================================================
             Cypher Commenter
             Enables Ctrl+/ (line comment with //) and Ctrl+Shift+/
             (block comment with /* */) in Cypher editor buffers.
             ==================================================================== -->
        <lang.commenter language="Cypher"
            implementationClass="com.graphdbplugin.language.CypherCommenter"/>

        <!-- ====================================================================
             File Editor Provider for Cypher Virtual Files
             Creates a CypherFileEditor whenever a CypherVirtualFile is opened,
             and hides the default text editor to avoid duplication.
             ==================================================================== -->
        <fileEditorProvider
            implementationClass="com.graphdbplugin.editor.CypherEditorProvider"/>

        <!-- ====================================================================
             Result tool window — shown at the bottom after query execution.
             Hosts QueryLogPanel, GraphVisualizationPanel, TableResultPanel,
             and ParametersPanel in a four-tab JBTabbedPane.
             doNotActivateOnStart: the window is shown programmatically by
             ResultToolWindowManager.displayResult when the first result arrives.
             ==================================================================== -->
        <toolWindow
            id="GraphDB Results"
            anchor="bottom"
            icon="/icons/graphdb.svg"
            factoryClass="com.graphdbplugin.results.ResultToolWindowFactory"
            doNotActivateOnStart="true"/>

        <!-- ====================================================================
             Project-Level Service: ResultToolWindowManager
             Bridges QueryExecutor results to the ResultPanel UI. Holds a
             reference to the ResultPanel once it is created by the factory
             and exposes displayResult() for use by RunQueryAction.
             ==================================================================== -->
        <projectService
            serviceInterface="com.graphdbplugin.results.ResultToolWindowManager"
            serviceImplementation="com.graphdbplugin.results.ResultToolWindowManager"/>

        <!-- Cypher annotator — provides real-time error highlighting in the editor -->
        <annotator
            language="Cypher"
            implementationClass="com.graphdbplugin.language.annotation.CypherAnnotator"/>

    </extensions>

    <!-- ========================================================================
         Actions
         Declares the data-source management actions that appear both in the
         tool-window toolbar and (optionally) in the main menu / context menu.
         ======================================================================== -->
    <actions>

        <!-- Action group that owns all data-source CRUD actions.
             This group is added to the tool-window toolbar programmatically
             by DataSourceTreePanel via ActionToolbar. -->
        <group
            id="GraphDB.DataSourceActions"
            text="Data Source Actions"
            description="Actions for managing GraphDB data sources"
            popup="false">

            <!-- Add a new Bolt data source -->
            <action
                id="GraphDB.AddDataSource"
                class="com.graphdbplugin.actions.AddDataSourceAction"
                text="Add Data Source"
                description="Add a new Neo4j/Bolt data source"
                icon="AllIcons.General.Add"/>

            <!-- Edit the currently selected data source -->
            <action
                id="GraphDB.EditDataSource"
                class="com.graphdbplugin.actions.EditDataSourceAction"
                text="Edit Data Source"
                description="Edit the selected Neo4j/Bolt data source"
                icon="AllIcons.Actions.Edit"/>

            <!-- Delete the currently selected data source -->
            <action
                id="GraphDB.DeleteDataSource"
                class="com.graphdbplugin.actions.DeleteDataSourceAction"
                text="Delete Data Source"
                description="Delete the selected Neo4j/Bolt data source"
                icon="AllIcons.General.Remove"/>

            <!-- Execute the Cypher query in the currently focused editor tab -->
            <action
                id="GraphDB.RunQuery"
                class="com.graphdbplugin.actions.RunQueryAction"
                text="Run Query"
                description="Execute the Cypher query against the selected data source"
                icon="AllIcons.Actions.Execute">
                <keyboard-shortcut first-keystroke="control F5" keymap="$default"/>
                <keyboard-shortcut first-keystroke="meta F5"    keymap="Mac OS X 10.5+"/>
            </action>

        </group>

    </actions>

    <!-- ========================================================================
         Application Listeners
         Register application-level lifecycle listeners.
         ======================================================================== -->
    <applicationListeners>
        <listener class="com.graphdbplugin.lifecycle.GraphDbApplicationLifecycle"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

</idea-plugin>
